# Chrome Enterprise Premium MCP Server
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The server loads .env automatically on startup. All variables are optional.
# The server runs in stdio mode with ADC by default.


# Authentication
#
# In stdio mode (default), the server authenticates to Google APIs using
# Application Default Credentials (ADC). Set these up with:
#
#   gcloud auth application-default login --scopes="<scopes>"
#   gcloud auth application-default set-quota-project YOUR_PROJECT_ID
#
# See README.md for the full scopes list.

# GCP project used for API enablement and quotas. Required if not set via gcloud CLI.
# Find your project ID at: https://console.cloud.google.com/cloud-resource-manager
# GOOGLE_CLOUD_QUOTA_PROJECT=your-project-id


# Transport
#
# The server defaults to stdio transport (for local MCP clients like Claude
# Desktop). Set GCP_STDIO=false to start an HTTP server instead.

GCP_STDIO=true
# PORT=3000


# OAuth (HTTP mode only)
#
# When running in HTTP mode, the server can require OAuth bearer tokens on
# tool calls. The MCP client (e.g., Gemini CLI) handles the OAuth flow and
# passes the user's access token through. The server validates it and uses
# it for Google API calls instead of ADC.
#
# To set up OAuth:
# 1. Create an OAuth 2.0 Client ID in your GCP project:
#    https://console.cloud.google.com/apis/credentials
#    Create Credentials > OAuth client ID > Web application
# 2. Set the authorized redirect URI to your client's callback
#    (e.g., http://localhost:7777/oauth/callback for Gemini CLI)
# 3. Copy the Client ID and Secret below.

# OAUTH_ENABLED=true
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
# GOOGLE_OAUTH_AUDIENCE=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:7777/oauth/callback

# Discovery endpoints served at .well-known/ paths so MCP clients can
# auto-discover how to authenticate. Set these to match your deployment.
# OAUTH_PROTECTED_RESOURCE=http://localhost:${PORT}/mcp
# OAUTH_AUTHORIZATION_SERVER=http://localhost:${PORT}/auth/google
# OAUTH_AUTHORIZATION_ENDPOINT=https://accounts.google.com/o/oauth2/v2/auth
# OAUTH_TOKEN_ENDPOINT=https://oauth2.googleapis.com/token


# Evaluations
#
# The eval runner uses Gemini as an LLM judge. Get an API key at:
#   https://aistudio.google.com/apikey

# GEMINI_API_KEY=your-gemini-api-key


# Feature Flags
#
# Experimental features are gated behind EXPERIMENT_ prefixed variables.
# All are disabled by default.

# Enable delete tools (delete DLP rules and detectors)
# EXPERIMENT_DELETE_TOOL_ENABLED=true
