    "axios": "^1.7.2",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "google-auth-library": "^10.4.0",
    "googleapis": "^166.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-n": "^17.2.0",
    "eslint-plugin-prettier": "^5.0.0",
    "esmock": "^2.7.1",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.0.0-alpha.20"
  }
