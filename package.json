{
  "name": "@google-cloud/chrome-management-mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "Chrome Management MCP server",
  "main": "mcp-server.js",
  "bin": {
    "chrome-management-mcp": "mcp-server.js"
  },
  "scripts": {
