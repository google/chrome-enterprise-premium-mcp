{
  "name": "@google-cloud/chrome-management-mcp",
  "version": "0.1.0",
  "description": "Chrome Management MCP server",
  "license": "Apache-2.0",
  "type": "module",
  "main": "mcp-server.js",
  "bin": {
    "chrome-management-mcp": "mcp-server.js"
  },
  "scripts": {
    "eval": "node test/evals/run.js",
    "eval:agentic": "node test/evals/run.js --category inspection,troubleshooting,mutation,discovery",
    "eval:full": "node test/evals/run.js --runs 3 --output results/eval-full.md",
    "eval:knowledge": "node test/evals/run.js --category knowledge",
    "format": "prettier --write .",
    "lint": "eslint .",
    "mcp-inspector": "npx @modelcontextprotocol/inspector node mcp-server.js",
    "start": "node mcp-server.js",
    "test": "node test/run-all.js",
    "test:integration:fake": "EXPERIMENT_DELETE_TOOL_ENABLED=true node test/run-integration.js fake",
    "test:integration:real": "EXPERIMENT_DELETE_TOOL_ENABLED=true node test/run-integration.js real",
    "test:smoke": "GCP_STDIO=false node test/local/smoke-test.js",
    "test:unit": "node test/run-unit.js"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "@google-cloud/service-usage": "^4.1.0",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "axios": "^1.7.2",
    "express": "^5.1.0",
    "google-auth-library": "^10.4.0",
    "googleapis": "^166.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@google-cloud/vertexai": "^1.11.0",
    "@google/generative-ai": "^0.24.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-n": "^17.2.0",
    "eslint-plugin-prettier": "^5.0.0",
    "esmock": "^2.7.1",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "uuid": "^13.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
