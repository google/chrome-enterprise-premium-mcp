    "test:python": "./test/run_python_tests.sh",
    "test": "./test/run_all_tests.sh",
    "smoke": "GCP_STDIO=false node test/local/smoke-test.js",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
